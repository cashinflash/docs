# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# Leftover vanilla-HTML artifacts (pre-Mintlify). Kept out so they
# don't creep back in and collide with /style.css or index.mdx.
*.html
app.js
styles.css
