{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cash in Flash Docs",
  "colors": {
    "primary": "#15C15D",
    "light": "#14E56B",
    "dark": "#11a44f"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "https://cashinflash.com/images/Get-Fast-Cash-Loans-Cash-in-Flash.png",
    "dark": "https://cashinflash.com/images/Get-Fast-Cash-Loans-Cash-in-Flash.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Find a Store",
        "href": "https://cashinflash.my.vergentlms.com/location-finder/results/CA/none/none"
      },
      {
        "label": "Loans",
        "href": "https://cashinflash.com/?page_id=11699"
      },
      {
        "label": "Western Union",
        "href": "https://cashinflash.com/western-union/"
      },
      {
        "label": "Money Tips",
        "href": "https://cashinflash.com/money-tips/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Home",
      "href": "https://cashinflash.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
